---
import {
  getLangFromUrl,
  getPathWithoutLang,
  localizePath,
  useTranslations,
} from "@/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const target = lang === "es" ? "en" : "es";
const href = localizePath(getPathWithoutLang(Astro.url), target);
---

<a
  href={href}
  aria-label={t("lang.switchLabel")}
  class="ml-1 flex items-center rounded-full border border-gray-300 px-2 py-1 text-xs font-semibold text-gray-600 transition hover:text-blue-500 dark:border-gray-600 dark:text-gray-200 dark:hover:text-blue-500"
>
  {target.toUpperCase()}
</a>
