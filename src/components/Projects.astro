---
import GitHub from "./icons/GitHub.astro";
import NextJS from "./icons/NextJS.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import Python from "./icons/Python.astro";
import Flutter from "./icons/Flutter.astro";
import AstroIcon from "./icons/AstroIcon.astro";
import React from "./icons/React.astro";
import Supabase from "./icons/Supabase.astro";
import TypeScript from "./icons/TypeScript.astro";
import FastAPI from "./icons/FastAPI.astro";
import Ai from "./icons/Ai.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const TAGS = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  SUPABASE: {
    name: "Supabase",
    class: "bg-[#3ECF8E] text-black",
    icon: Supabase,
  },
  PYTHON: {
    name: "Python",
    class: "bg-[#3776AB] text-white",
    icon: Python,
  },
  FASTAPI: {
    name: "FastAPI",
    class: "bg-[#009688] text-white",
    icon: FastAPI,
  },
  FLUTTER: {
    name: "Flutter",
    class: "bg-[#02569B] text-white",
    icon: Flutter,
  },
  ASTRO: {
    name: "Astro",
    class: "bg-[#FF5D01] text-white",
    icon: AstroIcon,
  },
  REACT: {
    name: "React",
    class: "bg-[#61DAFB] text-black",
    icon: React,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "bg-[#3178C6] text-white",
    icon: TypeScript,
  },
  AI: {
    name: "IA / Visión",
    class: "bg-[#6D28D9] text-white",
    icon: Ai,
  },
};
// Trabajos para clientes reales: los repos son privados, así que `github` queda
// vacío (el botón "Código" solo se muestra si hay URL). `link` apunta a la demo
// pública en vivo cuando existe.
const PROJECTS = [
  {
    title: {
      es: "Sistema Biométrico de Asistencia (IA facial)",
      en: "Biometric Attendance System (Facial AI)",
    },
    description: {
      es: "Solución completa de control de asistencia con reconocimiento facial para Rocky Sushi, diseñada como producto de marca blanca. Backend en Python/FastAPI con reconocimiento facial (dlib, embeddings de 128 dimensiones), app Flutter (kiosco + panel admin) para Android y Windows, motor de nómina y turnos, e instalador para Windows.",
      en: "Complete facial-recognition attendance solution for Rocky Sushi, designed as a white-label product. Python/FastAPI backend with facial recognition (dlib, 128-dimension embeddings), a Flutter app (kiosk + admin panel) for Android and Windows, a payroll and shifts engine, and a Windows installer.",
    },
    link: "",
    github: "",
    image: "/projects/RockySushi.webp",
    alt: {
      es: "Panel administrativo del sistema biométrico de asistencia de Rocky Sushi",
      en: "Admin panel of Rocky Sushi's biometric attendance system",
    },
    tags: [TAGS.AI, TAGS.FASTAPI, TAGS.FLUTTER, TAGS.SUPABASE],
  },
  {
    title: {
      es: "Palaliga — Gestión de Ligas de Pádel",
      en: "Palaliga — Padel League Management",
    },
    description: {
      es: "Plataforma multi-tenant (marca blanca) para crear y administrar ligas de pádel: generación automática de calendario round-robin, tabla de clasificación en tiempo real y cuadros de playoffs. Aislamiento por organización con Row-Level Security y actualizaciones en vivo.",
      en: "Multi-tenant (white-label) platform to create and manage padel leagues: automatic round-robin schedule generation, real-time standings, and playoff brackets. Per-organization isolation with Row-Level Security and live updates.",
    },
    link: "https://palaliga.vercel.app",
    github: "",
    image: "/projects/Palaliga.webp",
    alt: {
      es: "Interfaz de Palaliga mostrando la gestión de una liga de pádel",
      en: "Palaliga interface showing padel league management",
    },
    tags: [TAGS.FLUTTER, TAGS.SUPABASE],
  },
  {
    title: {
      es: "Hogarly — Organización del hogar en familia",
      en: "Hogarly — Family Home Organization",
    },
    description: {
      es: "PWA colaborativa para organizar el hogar: tareas con recompensas por puntos, lista de compras en vivo, comidas, calendario y notificaciones push. Construida con Next.js y Supabase, con monitorización de errores (Sentry) y pruebas end-to-end.",
      en: "Collaborative PWA to organize the household: point-based chore rewards, live shopping list, meals, calendar, and push notifications. Built with Next.js and Supabase, with error monitoring (Sentry) and end-to-end tests.",
    },
    link: "https://app.hogarly.app",
    github: "",
    image: "/projects/Hogarly.webp",
    alt: {
      es: "Aplicación Hogarly para organizar tareas y compras del hogar en familia",
      en: "Hogarly app for organizing household chores and shopping as a family",
    },
    tags: [TAGS.NEXT, TAGS.TYPESCRIPT, TAGS.SUPABASE, TAGS.TAILWIND],
  },
  {
    title: {
      es: "DropWear — Punto de Venta e Inventario",
      en: "DropWear — Point of Sale & Inventory",
    },
    description: {
      es: "Sistema POS y de gestión de inventario en tiempo real para una tienda de ropa, con control de acceso por roles (socio, vendedor, administrador). Inventario sincronizado en vivo entre dispositivos mediante Supabase Realtime.",
      en: "Real-time POS and inventory management system for a clothing store, with role-based access control (partner, seller, admin). Inventory synced live across devices via Supabase Realtime.",
    },
    link: "",
    github: "",
    image: "/projects/DropWear.webp",
    alt: {
      es: "Logotipo de DropWear, sistema de punto de venta e inventario",
      en: "DropWear logo, a point-of-sale and inventory system",
    },
    tags: [TAGS.REACT, TAGS.TYPESCRIPT, TAGS.SUPABASE, TAGS.TAILWIND],
  },
  {
    title: {
      es: "La Casa de Ramona — Web",
      en: "La Casa de Ramona — Website",
    },
    description: {
      es: "Sitio web bilingüe de renta vacacional de lujo en Puerto Peñasco. Optimizado para SEO, velocidad de carga y conversión de reservas, con formulario de contacto y reservación directa por WhatsApp.",
      en: "Bilingual website for a luxury vacation rental in Puerto Peñasco. Optimized for SEO, load speed, and booking conversion, with a contact form and direct booking via WhatsApp.",
    },
    link: "https://www.lacasaderamona.com",
    github: "",
    image: "/projects/Lacasaderamona.webp",
    alt: {
      es: "Sitio web de la renta vacacional de lujo La Casa de Ramona",
      en: "Website of the luxury vacation rental La Casa de Ramona",
    },
    tags: [TAGS.ASTRO, TAGS.REACT, TAGS.TAILWIND],
  },
  {
    title: {
      es: "Estrella Brothers Carpentry — Web",
      en: "Estrella Brothers Carpentry — Website",
    },
    description: {
      es: "Sitio de portafolio bilingüe para una carpintería en Phoenix, Arizona. Galería de proyectos con comparador antes/después, contenido tipado (Content Collections + Zod), optimización de imágenes y SEO local con datos estructurados.",
      en: "Bilingual portfolio site for a carpentry business in Phoenix, Arizona. Project gallery with before/after slider, typed content (Content Collections + Zod), image optimization, and local SEO with structured data.",
    },
    link: "https://www.estrellabrotherscarpentry.com",
    github: "",
    image: "/projects/EstrellaBrothers.webp",
    alt: {
      es: "Trabajo de carpintería de Estrella Brothers: construcción de un patio techado",
      en: "Estrella Brothers carpentry work: building a covered patio",
    },
    tags: [TAGS.ASTRO, TAGS.TYPESCRIPT, TAGS.TAILWIND],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, alt, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
            <img
              alt={alt[lang]}
              class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
              loading="lazy"
              src={image}
            />
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {title[lang]}
          </h3>
          <div class="flex flex-wrap mt-2">
            <ul class="flex flex-row mb-2 gap-x-2">
              {tags.map((tag) => (
                <li>
                  <span
                    class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                  >
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400">
              {description[lang]}
            </div>
            <footer class="flex items-end justify-start mt-4 gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-6" />
                  {t("project.code")}
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  {t("project.viewLive")}
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>
