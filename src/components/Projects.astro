---
import GitHub from "./icons/GitHub.astro";
import NextJS from "./icons/NextJS.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import Python from "./icons/Python.astro";
import Flutter from "./icons/Flutter.astro";
import AstroIcon from "./icons/AstroIcon.astro";
import React from "./icons/React.astro";
import Supabase from "./icons/Supabase.astro";
import TypeScript from "./icons/TypeScript.astro";
import FastAPI from "./icons/FastAPI.astro";
import Ai from "./icons/Ai.astro";

const TAGS = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  SUPABASE: {
    name: "Supabase",
    class: "bg-[#3ECF8E] text-black",
    icon: Supabase,
  },
  PYTHON: {
    name: "Python",
    class: "bg-[#3776AB] text-white",
    icon: Python,
  },
  FASTAPI: {
    name: "FastAPI",
    class: "bg-[#009688] text-white",
    icon: FastAPI,
  },
  FLUTTER: {
    name: "Flutter",
    class: "bg-[#02569B] text-white",
    icon: Flutter,
  },
  ASTRO: {
    name: "Astro",
    class: "bg-[#FF5D01] text-white",
    icon: AstroIcon,
  },
  REACT: {
    name: "React",
    class: "bg-[#61DAFB] text-black",
    icon: React,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "bg-[#3178C6] text-white",
    icon: TypeScript,
  },
  AI: {
    name: "IA / Visión",
    class: "bg-[#6D28D9] text-white",
    icon: Ai,
  },
};
// Trabajos para clientes reales: los repos son privados, así que `github` queda
// vacío (el botón "Código" solo se muestra si hay URL). `link` apunta a la demo
// pública en vivo cuando existe.
const PROJECTS = [
  {
    title: "Sistema Biométrico de Asistencia (IA facial)",
    description:
      "Solución completa de control de asistencia con reconocimiento facial para Rocky Sushi, diseñada como producto de marca blanca. Backend en Python/FastAPI con reconocimiento facial (dlib, embeddings de 128 dimensiones), app Flutter (kiosco + panel admin) para Android y Windows, motor de nómina y turnos, e instalador para Windows.",
    link: "",
    github: "",
    image: "/projects/RockySushi.webp",
    alt: "Panel administrativo del sistema biométrico de asistencia de Rocky Sushi",
    tags: [TAGS.AI, TAGS.FASTAPI, TAGS.FLUTTER, TAGS.SUPABASE],
  },
  {
    title: "Palaliga — Gestión de Ligas de Pádel",
    description:
      "Plataforma multi-tenant (marca blanca) para crear y administrar ligas de pádel: generación automática de calendario round-robin, tabla de clasificación en tiempo real y cuadros de playoffs. Aislamiento por organización con Row-Level Security y actualizaciones en vivo.",
    link: "https://palaliga.vercel.app",
    github: "",
    image: "/projects/BlingRR.webp",
    alt: "Interfaz de Palaliga mostrando la gestión de una liga de pádel",
    tags: [TAGS.FLUTTER, TAGS.SUPABASE],
  },
  {
    title: "Hogarly — Organización del hogar en familia",
    description:
      "PWA colaborativa para organizar el hogar: tareas con recompensas por puntos, lista de compras en vivo, comidas, calendario y notificaciones push. Construida con Next.js y Supabase, con monitorización de errores (Sentry) y pruebas end-to-end.",
    link: "https://app.hogarly.app",
    github: "",
    image: "/projects/Hogarly.webp",
    alt: "Aplicación Hogarly para organizar tareas y compras del hogar en familia",
    tags: [TAGS.NEXT, TAGS.TYPESCRIPT, TAGS.SUPABASE, TAGS.TAILWIND],
  },
  {
    title: "DropWear — Punto de Venta e Inventario",
    description:
      "Sistema POS y de gestión de inventario en tiempo real para una tienda de ropa, con control de acceso por roles (socio, vendedor, administrador). Inventario sincronizado en vivo entre dispositivos mediante Supabase Realtime.",
    link: "",
    github: "",
    image: "/projects/DropWear.webp",
    alt: "Logotipo de DropWear, sistema de punto de venta e inventario",
    tags: [TAGS.REACT, TAGS.TYPESCRIPT, TAGS.SUPABASE, TAGS.TAILWIND],
  },
  {
    title: "La Casa de Ramona — Web",
    description:
      "Sitio web bilingüe de renta vacacional de lujo en Puerto Peñasco. Optimizado para SEO, velocidad de carga y conversión de reservas, con formulario de contacto y reservación directa por WhatsApp.",
    link: "https://www.lacasaderamona.com",
    github: "",
    image: "/projects/Lacasaderamona.webp",
    alt: "Sitio web de la renta vacacional de lujo La Casa de Ramona",
    tags: [TAGS.ASTRO, TAGS.REACT, TAGS.TAILWIND],
  },
  {
    title: "Estrella Brothers Carpentry — Web",
    description:
      "Sitio de portafolio bilingüe para una carpintería en Phoenix, Arizona. Galería de proyectos con comparador antes/después, contenido tipado (Content Collections + Zod), optimización de imágenes y SEO local con datos estructurados.",
    link: "https://www.estrellabrotherscarpentry.com",
    github: "",
    image: "/projects/EstrellaBrothers.webp",
    alt: "Trabajo de carpintería de Estrella Brothers: construcción de un patio techado",
    tags: [TAGS.ASTRO, TAGS.TYPESCRIPT, TAGS.TAILWIND],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, alt, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
            <img
              alt={alt}
              class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
              loading="lazy"
              src={image}
            />
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {title}
          </h3>
          <div class="flex flex-wrap mt-2">
            <ul class="flex flex-row mb-2 gap-x-2">
              {tags.map((tag) => (
                <li>
                  <span
                    class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                  >
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400">
              {description}
            </div>
            <footer class="flex items-end justify-start mt-4 gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-6" />
                  Código
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  Ver en vivo
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>
