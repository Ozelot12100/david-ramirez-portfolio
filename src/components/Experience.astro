---
import ExperienceItem from "./ExperienceItem.astro";
const EXPERIENCE = [
  {
    date: "2022 - Actualidad",
    title: "Desarrollador de Software Freelance",
    company: "Proyectos Independientes / Negocios Locales",
    description:
      "Desarrollo de soluciones de software a medida para negocios reales en México y Estados Unidos: desde un sistema de asistencia con reconocimiento facial (IA) y plataformas multi-tenant de marca blanca, hasta sistemas de punto de venta en tiempo real y sitios web optimizados para conversión. Backend escalable con Python/FastAPI y Supabase, apps multiplataforma con Flutter (Android, Windows y web) y arquitecturas modernas (MVVM, Clean Architecture, offline-first).",
  },
];
---

<ol class="relative mt-16">
  {
    EXPERIENCE.map((experience) => (
      <li class="">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>
