---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { getLangFromUrl, useTranslations, localizePath } from "@/i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = localizePath("/", lang);

const navItems = [
  {
    title: t("nav.experience"),
    label: "experiencia",
    url: `${base}#experiencia`,
  },
  {
    title: t("nav.projects"),
    label: "proyectos",
    url: `${base}#proyectos`,
  },
  {
    title: t("nav.tech"),
    label: "tecnologias",
    url: `${base}#tecnologias`,
  },
  {
    title: t("nav.about"),
    label: "sobre-mi",
    url: `${base}#sobre-mi`,
  },
  {
    title: t("nav.contact"),
    label: "contacto",
    url: "mailto:garrapatin12100@gmail.com",
  },
];
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full px-2 mx-auto mt-2"
>
  <!--
    La píldora mide lo que su contenido (y el header la centra) hasta que no
    cabe; ahí `max-w-full` la limita al ancho de la pantalla.
  -->
  <div
    class="nav-pill flex items-center max-w-full px-3 text-sm font-medium rounded-full text-gray-600 dark:text-gray-200"
  >
    <!--
      Solo los ENLACES se desplazan. Los toggles van FUERA de este contenedor a
      propósito: `overflow-x: auto` obliga a `overflow-y` a pasar de `visible` a
      `auto`, y eso recortaba el menú desplegable del ThemeToggle.
      Y sin `justify-center`: al centrar contenido que desborda, el lado
      izquierdo queda fuera de pantalla e inalcanzable (cortaba "Experiencia").
    -->
    <nav class="flex items-center min-w-0 overflow-x-auto">
      {
        navItems.map((link) => (
          <a
            class="relative block px-2 py-2 transition shrink-0 whitespace-nowrap hover:text-blue-500 dark:hover:text-blue-500"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center shrink-0">
      <ThemeToggle />
      <LanguageToggle />
    </div>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section");
    const navItems = document.querySelectorAll("header nav a");

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("text-blue-500");
            } else {
              item.classList.remove("text-blue-500");
            }
          });
        }
      });
    };

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    });

    sections.forEach((section) => {
      observer.observe(section);
    });

    // Cleanup function
    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect();
      } else {
        sections.forEach((section) => {
          observer.observe(section);
        });
      }
    };
  });
</script>

<style>
  .nav-pill {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  .nav-pill {
    @apply dark:bg-gray-800/90 bg-white/50;
  }

  /* El carrusel de enlaces se desplaza en móvil, pero sin barra visible. */
  nav {
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* Edge antiguo */
  }

  nav::-webkit-scrollbar {
    display: none; /* Chrome / Safari */
  }

  @keyframes nav-shadown {
    0% {
      @apply dark:bg-gray-800/0 bg-white/0;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur ring-white/10;
    }
  }
</style>
