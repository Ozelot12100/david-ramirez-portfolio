---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/ui";

const t = useTranslations(getLangFromUrl(Astro.url));
---

<Layout title={`${t("notFound.title")} - David A. Ramírez`} description={t("notFound.text")}>
  <main class="px-4">
    <SectionContainer class="py-44 text-center">
      <h1 class="text-6xl font-bold text-gray-800 dark:text-white">404</h1>
      <p class="mt-6 text-xl text-gray-800 dark:text-gray-300">
        {t("notFound.text")}
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 px-4 py-2 mt-8 text-gray-800 transition bg-gray-100 border border-gray-300 rounded-full dark:bg-gray-800 dark:border-gray-600 dark:text-white hover:bg-gray-900 hover:border-gray-700 hover:text-white dark:hover:bg-gray-100 dark:hover:border-gray-300 dark:hover:text-black"
      >
        {t("notFound.back")}
      </a>
    </SectionContainer>
  </main>
</Layout>
